{
  "expo": {
    "name": "Lovly",
    "slug": "loviq",
    "scheme": "lovly",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.pritambhingole.lovly",
      "googleServicesFile": "./GoogleService-Info.plist",
      "usesAppleSignIn": true,
      "infoPlist": {
        "NSUserNotificationUsageDescription": "Notifications help you receive new matches and messages.",
        "NSCameraUsageDescription": "Camera permission is required to capture verification selfies and make video calls.",
        "NSMicrophoneUsageDescription": "Microphone permission is required to connect your voice and video calls.",
        "NSLocationWhenInUseUsageDescription": "Lovly uses your location to find nearby matches and show approximate distances.",
        "NSPhotoLibraryUsageDescription": "Lovly requires access to your photo library to select and upload profile pictures",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.pritambhingole.lovly",
      "versionCode": 1,
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "backgroundColor": "#120A1C",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png"
      },
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "loviq.vercel.app"
            },
            {
              "scheme": "https",
              "host": "lovlyapp.com"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        },
        {
          "action": "VIEW",
          "data": [
            {
              "scheme": "lovly"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {},
    "plugins": [
      "expo-secure-store",
      "@react-native-firebase/app",
      "@react-native-firebase/auth",
      "@react-native-community/datetimepicker",
      "expo-web-browser",
      "expo-notifications",
      "expo-apple-authentication",
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "dcecb368-1d92-412a-9aae-d3db33e2b129"
      }
    },
    "owner": "pritam9773"
  }
}
