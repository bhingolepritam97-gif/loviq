# --- Database (Neon free tier: https://neon.tech) ---
# Get this from your Neon project dashboard. Must include ?sslmode=require
DATABASE_URL=postgres://user:password@ep-xxxx.us-east-2.aws.neon.tech/loviq?sslmode=require

# --- Firebase Admin (for verifying ID tokens issued by Firebase Auth) ---
# Download from Firebase Console -> Project Settings -> Service Accounts -> Generate new private key
# Paste the whole JSON contents as a single line, or point to a file path instead (see src/config/firebase.js)
FIREBASE_SERVICE_ACCOUNT_JSON=

# --- Server ---
PORT=4000
NODE_ENV=development

# --- Rate limiting ---
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
